# Copy this to .env for local development — NEVER commit .env
# All of these must also be added as GitHub Actions secrets for CI/CD.

# ── Google ────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here
GMAIL_DELEGATE_EMAIL=you@gmail.com
GMAIL_REFRESH_TOKEN=your_refresh_token
GMAIL_CLIENT_ID=your_client_id
GMAIL_CLIENT_SECRET=your_client_secret

# ── Shopify ───────────────────────────────────────────────────
SHOPIFY_SHOP_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx
# Location GID: Shopify Admin → Settings → Locations → copy from URL
SHOPIFY_LOCATION_ID=gid://shopify/Location/xxxxxxxxxxxxxxx

# ── Alerts ───────────────────────────────────────────────────
ALERTS_RECIPIENT=you@gmail.com
