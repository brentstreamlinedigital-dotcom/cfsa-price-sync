# Copy this to .env for local development — NEVER commit .env

# Google service account JSON path (Cloud Run uses ADC — leave blank)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json

# Shopify (only needed locally — Cloud Run reads from Secret Manager)
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Override config values locally
CFSA_DRY_RUN=false
